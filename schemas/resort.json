{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ski Resort Index",
  "type": "object",
  "required": ["version", "generated_at", "total_resorts", "resorts"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "total_resorts": {
      "type": "integer",
      "minimum": 0
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resorts": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/resort"
      }
    }
  },
  "definitions": {
    "resort": {
      "type": "object",
      "required": ["id", "name", "names", "type", "bbox", "area_km2"],
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Primary display name"
        },
        "names": {
          "type": "array",
          "minItems": 1,
          "description": "All searchable name variants",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "type": {
          "type": "string",
          "enum": ["domain", "resort"]
        },
        "parent_id": {
          "type": ["integer", "null"]
        },
        "parent_name": {
          "type": ["string", "null"]
        },
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "number"
          },
          "description": "[west, south, east, north] in decimal degrees"
        },
        "area_km2": {
          "type": "number",
          "minimum": 0
        },
        "country": {
          "type": ["string", "null"],
          "pattern": "^[A-Z]{2}$"
        }
      }
    }
  }
}
